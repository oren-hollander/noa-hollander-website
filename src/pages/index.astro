---
import Layout from '../layouts/Layout.astro';
const base = import.meta.env.BASE_URL;
---

<Layout title="Noa Hollander — Aviation Management">

  <!-- ═══════════════ NAVIGATION ═══════════════ -->
  <nav class="nav" id="nav">
    <div class="nav-inner">
      <a href="#hero" class="nav-logo">NH</a>
      <div class="nav-links" id="nav-links">
        <a href="#about">About</a>
        <a href="#education">Education</a>
        <a href="#experience">Experience</a>
        <a href="#awards">Awards</a>
        <a href="#contact">Contact</a>
      </div>
      <button class="nav-toggle" id="nav-toggle" aria-label="Toggle menu">
        <span></span>
        <span></span>
      </button>
    </div>
  </nav>

  <!-- ═══════════════ HERO ═══════════════ -->
  <section id="hero" class="hero">
    <div class="hero-bg">
      <div class="hero-gradient"></div>
      <div class="hero-stars"></div>
      <div class="hero-glow"></div>
    </div>
    <div class="hero-content">
      <h1 class="hero-name">
        <span class="hero-name-line">Noa</span>
        <span class="hero-name-line">Hollander</span>
      </h1>
      <div class="hero-divider"></div>
      <p class="hero-tagline">Aviation Management · Israeli Air Force Veteran</p>
    </div>
    <div class="hero-scroll-hint">
      <span>Scroll</span>
      <div class="scroll-line"></div>
    </div>
  </section>

  <!-- ═══════════════ ABOUT ═══════════════ -->
  <section id="about" class="section">
    <div class="container">
      <span class="section-label">About</span>
      <p class="about-text" data-reveal-text>
        From coordinating helicopter squadron training plans in the Israeli Air Force
        to pursuing a degree in Aviation Management at Florida Tech — my path has always
        pointed skyward. I combine military discipline with academic excellence, driven
        by a vision of shaping the future of airport planning and design.
      </p>
    </div>
  </section>

  <!-- ═══════════════ EDUCATION ═══════════════ -->
  <section id="education" class="section section--alt">
    <div class="container">
      <span class="section-label">Education</span>
      <div class="edu-layout">
        <div class="gpa-display">
          <span class="gpa-number">4.0</span>
          <span class="gpa-label">GPA</span>
        </div>
        <div class="edu-details">
          <h2 class="edu-school">Florida Institute of Technology</h2>
          <p class="edu-location">Melbourne, FL</p>
          <p class="edu-degree">Bachelor of Science in Aviation Management</p>
          <p class="edu-date">Expected Graduation · May 2028</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════ EXPERIENCE ═══════════════ -->
  <section id="experience" class="section">
    <div class="container">
      <span class="section-label">Experience</span>

      <div class="exp-card exp-card--military">
        <div class="exp-accent"></div>
        <div class="exp-body">
          <div class="exp-header">
            <div>
              <h3 class="exp-org">Israeli Air Force</h3>
              <p class="exp-role">Staff Sergeant · Training Planning & Coordination NCO</p>
            </div>
            <span class="exp-date">May 2021 — Sep 2023</span>
          </div>
          <ul class="exp-list">
            <li>Oversaw training plans for operational helicopter squadrons, ensuring operational proficiency</li>
            <li>Developed and managed training exercises in a dynamic, high-pressure environment</li>
            <li>Coordinated flight plans in communication with multiple units and authorities</li>
            <li>Maintained pilot records and detailed flight logs in compliance with military standards</li>
            <li>Optimized and implemented new procedures to improve efficiency and safety</li>
          </ul>
        </div>
      </div>

      <div class="exp-card">
        <div class="exp-accent"></div>
        <div class="exp-body">
          <div class="exp-header">
            <div>
              <h3 class="exp-org">Florida Institute of Technology</h3>
              <p class="exp-role">Residence Life Marketing & Communication Assistant</p>
            </div>
            <span class="exp-date">Sep 2025 — Present</span>
          </div>
          <ul class="exp-list">
            <li>Promoted Residence Life and Housing events through social media and publications</li>
            <li>Designed and produced marketing materials for departmental branding and outreach</li>
          </ul>
        </div>
      </div>

      <div class="exp-card">
        <div class="exp-accent"></div>
        <div class="exp-body">
          <div class="exp-header">
            <div>
              <h3 class="exp-org">Florida Institute of Technology</h3>
              <p class="exp-role">Resident Assistant</p>
            </div>
            <span class="exp-date">Aug 2025 — Present</span>
          </div>
          <ul class="exp-list">
            <li>Assisted 380 students by providing resources and support for academic and personal success</li>
            <li>Developed educational and interactive programs tailored to residents' interests</li>
            <li>Planned, organized, and executed three monthly events for community engagement</li>
            <li>Collaborated with staff on conflict resolution to support a positive living environment</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════ AWARDS ═══════════════ -->
  <section id="awards" class="section section--alt">
    <div class="container">
      <span class="section-label">Awards & Honors</span>
      <div class="awards-grid">
        <div class="award-card">
          <div class="award-icon">★</div>
          <div class="award-year">2025</div>
          <h3 class="award-name">Tony Jannus Distinguished Aviation Society Scholars Award</h3>
        </div>
        <div class="award-card">
          <div class="award-icon">★</div>
          <div class="award-year">2024–25</div>
          <h3 class="award-name">Dean's List</h3>
          <p class="award-detail">2 consecutive semesters</p>
        </div>
        <div class="award-card">
          <div class="award-icon">★</div>
          <div class="award-year">2022</div>
          <h3 class="award-name">Tel Nof Airbase Excellence Award</h3>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════ SKILLS & ACTIVITIES ═══════════════ -->
  <section id="skills" class="section">
    <div class="container two-col">
      <div>
        <span class="section-label">Skills</span>
        <div class="skills-grid">
          <span class="skill-tag">Leadership & Team Coordination</span>
          <span class="skill-tag">High-Pressure Adaptability</span>
          <span class="skill-tag">Attention to Detail</span>
          <span class="skill-tag">Records & Data Management</span>
          <span class="skill-tag">Procedure Implementation</span>
          <span class="skill-tag">Microsoft Office</span>
          <span class="skill-tag">Canva</span>
        </div>
      </div>
      <div>
        <span class="section-label">Activities</span>
        <div class="activities-list">
          <div class="activity-item">
            <span class="activity-role">Secretary & Historian</span>
            <span class="activity-org">International Society of Air Safety Investigators</span>
            <span class="activity-date">Dec 2024 — Present</span>
          </div>
          <div class="activity-item">
            <span class="activity-role">Treasurer & Secretary</span>
            <span class="activity-org">Florida Tech's Mishpacha</span>
            <span class="activity-date">Feb 2025 — Present</span>
          </div>
          <div class="activity-item">
            <span class="activity-role">Secretary</span>
            <span class="activity-org">Phi Eta Sigma National Honor Society</span>
            <span class="activity-date">May 2025 — Present</span>
          </div>
          <div class="activity-item">
            <span class="activity-role">Member</span>
            <span class="activity-org">Collegiate Aviation Business Executives</span>
            <span class="activity-date">Oct 2024</span>
          </div>
          <div class="activity-item">
            <span class="activity-role">Member</span>
            <span class="activity-org">Women in Aviation, Florida Tech Chapter</span>
            <span class="activity-date">Oct 2024</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════ CONTACT ═══════════════ -->
  <section id="contact" class="section section--alt">
    <div class="container contact-content">
      <span class="section-label">Get in Touch</span>
      <h2 class="contact-heading">Let's Connect</h2>
      <div class="contact-links">
        <a href="tel:321-381-1034" class="contact-link">
          <span class="contact-link-label">Phone</span>
          <span class="contact-link-value">321-381-1034</span>
        </a>
        <a href="mailto:nhollander2024@my.fit.edu" class="contact-link">
          <span class="contact-link-label">Email</span>
          <span class="contact-link-value">nhollander2024@my.fit.edu</span>
        </a>
        <a href="https://linkedin.com/in/noa-hollander" target="_blank" rel="noopener" class="contact-link">
          <span class="contact-link-label">LinkedIn</span>
          <span class="contact-link-value">linkedin.com/in/noa-hollander</span>
        </a>
      </div>
      <img src={`${base}images/signature.png`} alt="" class="contact-signature" />
    </div>
  </section>

  <footer class="footer">
    <p>&copy; 2026 Noa Hollander</p>
  </footer>

</Layout>

<!-- ═══════════════════════════════════════════════════════
     STYLES
     ═══════════════════════════════════════════════════════ -->
<style is:global>

  /* ── Navigation ── */
  .nav {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    z-index: 1000;
    padding: 1.25rem 2rem;
    transition: background-color 0.4s ease, backdrop-filter 0.4s ease;
  }
  .nav.scrolled {
    background-color: rgba(10, 15, 26, 0.88);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
  }
  .nav-inner {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .nav-logo {
    font-size: 1.25rem;
    font-weight: 800;
    letter-spacing: -0.02em;
    color: var(--text);
    transition: color 0.3s;
  }
  .nav-logo:hover { color: var(--accent); }
  .nav-links {
    display: flex;
    gap: 2.5rem;
  }
  .nav-links a {
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--text-secondary);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    transition: color 0.3s;
  }
  .nav-links a:hover { color: var(--text); }
  .nav-toggle {
    display: none;
    background: none;
    border: none;
    cursor: pointer;
    width: 28px;
    height: 20px;
    position: relative;
  }
  .nav-toggle span {
    display: block;
    width: 100%;
    height: 2px;
    background: var(--text);
    position: absolute;
    left: 0;
    transition: transform 0.3s, opacity 0.3s;
  }
  .nav-toggle span:first-child { top: 4px; }
  .nav-toggle span:last-child { bottom: 4px; }
  .nav.open .nav-toggle span:first-child {
    transform: rotate(45deg) translate(4px, 4px);
  }
  .nav.open .nav-toggle span:last-child {
    transform: rotate(-45deg) translate(4px, -4px);
  }

  @media (max-width: 768px) {
    .nav-links {
      display: none;
      position: absolute;
      top: 100%;
      left: 0;
      width: 100%;
      flex-direction: column;
      gap: 0;
      background: rgba(10, 15, 26, 0.95);
      backdrop-filter: blur(16px);
      padding: 1rem 2rem 2rem;
    }
    .nav.open .nav-links { display: flex; }
    .nav-links a {
      padding: 0.75rem 0;
      font-size: 0.85rem;
    }
    .nav-toggle { display: block; }
  }

  /* ── Hero ── */
  .hero {
    height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    overflow: hidden;
  }
  .hero-bg {
    position: absolute;
    inset: 0;
  }
  .hero-gradient {
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 50% 30%, #141e35 0%, #0a0f1a 70%);
  }
  .hero-stars {
    position: absolute;
    inset: 0;
    background-image:
      radial-gradient(1px 1px at 50px 30px, rgba(255,255,255,0.8), transparent),
      radial-gradient(1.2px 1.2px at 150px 80px, rgba(255,255,255,0.6), transparent),
      radial-gradient(1px 1px at 100px 130px, rgba(255,255,255,0.5), transparent),
      radial-gradient(1.5px 1.5px at 200px 50px, rgba(255,255,255,0.4), transparent),
      radial-gradient(1px 1px at 25px 110px, rgba(255,255,255,0.6), transparent),
      radial-gradient(1px 1px at 175px 145px, rgba(255,255,255,0.3), transparent),
      radial-gradient(1.3px 1.3px at 250px 100px, rgba(255,255,255,0.5), transparent),
      radial-gradient(1px 1px at 300px 20px, rgba(255,255,255,0.4), transparent);
    background-size: 350px 180px;
    animation: twinkle 6s ease-in-out infinite alternate;
  }
  @keyframes twinkle {
    0% { opacity: 0.3; }
    100% { opacity: 0.55; }
  }
  .hero-glow {
    position: absolute;
    width: 700px;
    height: 700px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(96, 165, 250, 0.06) 0%, transparent 70%);
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
  }
  .hero-content {
    position: relative;
    z-index: 1;
    text-align: center;
  }
  .hero-name {
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .hero-name-line {
    display: block;
    font-size: clamp(4.5rem, 13vw, 11rem);
    font-weight: 900;
    line-height: 0.88;
    letter-spacing: -0.04em;
    background: linear-gradient(180deg, #f1f5f9 20%, #7c8da6 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  .hero-divider {
    width: 60px;
    height: 2px;
    background: linear-gradient(90deg, var(--accent), var(--gold));
    margin: 2rem auto;
    transform-origin: center;
  }
  .hero-tagline {
    font-size: clamp(0.85rem, 1.8vw, 1.15rem);
    font-weight: 400;
    color: var(--text-secondary);
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }
  .hero-scroll-hint {
    position: absolute;
    bottom: 2.5rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    z-index: 1;
  }
  .hero-scroll-hint span {
    font-size: 0.65rem;
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--text-muted);
  }
  .scroll-line {
    width: 1px;
    height: 40px;
    background: linear-gradient(to bottom, var(--text-muted), transparent);
    transform-origin: top;
  }

  /* ── Sections ── */
  .section {
    min-height: 100vh;
    display: flex;
    align-items: center;
    padding: 8rem 2rem;
    position: relative;
  }
  .section--alt {
    background: var(--bg-alt);
  }
  .section + .section::before {
    content: '';
    position: absolute;
    top: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 240px;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(96, 165, 250, 0.2), transparent);
  }
  .container {
    max-width: 1100px;
    width: 100%;
    margin: 0 auto;
  }
  .section-label {
    display: inline-block;
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 2rem;
  }

  /* ── About ── */
  .about-text {
    font-size: clamp(1.4rem, 3vw, 2.2rem);
    font-weight: 400;
    line-height: 1.5;
    color: var(--text);
    max-width: 900px;
  }

  /* ── Education ── */
  .edu-layout {
    display: flex;
    align-items: center;
    gap: 4rem;
  }
  .gpa-display {
    display: flex;
    flex-direction: column;
    align-items: center;
    flex-shrink: 0;
  }
  .gpa-number {
    font-size: clamp(5rem, 12vw, 9rem);
    font-weight: 900;
    line-height: 1;
    letter-spacing: -0.04em;
    background: linear-gradient(135deg, var(--accent) 0%, var(--gold) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  .gpa-label {
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-top: 0.5rem;
  }
  .edu-details {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .edu-school {
    font-size: clamp(1.5rem, 3vw, 2.2rem);
    font-weight: 800;
    line-height: 1.2;
  }
  .edu-location {
    font-size: 1rem;
    color: var(--text-secondary);
  }
  .edu-degree {
    font-size: 1.1rem;
    font-weight: 500;
    color: var(--text);
    margin-top: 0.5rem;
  }
  .edu-date {
    font-size: 0.9rem;
    color: var(--text-muted);
  }
  @media (max-width: 768px) {
    .edu-layout {
      flex-direction: column;
      text-align: center;
      gap: 2rem;
    }
  }

  /* ── Experience ── */
  .exp-card {
    display: flex;
    background: var(--bg-card);
    border-radius: 12px;
    overflow: hidden;
    margin-bottom: 1.5rem;
    border: 1px solid var(--border);
    transition: border-color 0.3s, background 0.3s;
  }
  .exp-card:hover {
    border-color: var(--border-light);
    background: var(--bg-card-hover);
  }
  .exp-accent {
    width: 4px;
    flex-shrink: 0;
    background: var(--accent);
  }
  .exp-card--military .exp-accent {
    background: linear-gradient(to bottom, var(--gold), var(--gold-light));
  }
  .exp-body {
    padding: 2rem 2.5rem;
    width: 100%;
  }
  .exp-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 1rem;
    margin-bottom: 1.25rem;
  }
  .exp-org {
    font-size: 1.25rem;
    font-weight: 700;
  }
  .exp-role {
    font-size: 0.95rem;
    color: var(--text-secondary);
    margin-top: 0.25rem;
  }
  .exp-date {
    font-size: 0.8rem;
    font-weight: 500;
    color: var(--text-muted);
    white-space: nowrap;
    flex-shrink: 0;
    padding-top: 0.25rem;
  }
  .exp-list li {
    font-size: 0.92rem;
    color: var(--text-secondary);
    line-height: 1.7;
    padding-left: 1rem;
    position: relative;
  }
  .exp-list li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.7em;
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: var(--text-muted);
  }
  .exp-card--military .exp-list li::before {
    background: var(--gold);
  }
  @media (max-width: 640px) {
    .exp-header { flex-direction: column; }
    .exp-body { padding: 1.5rem; }
  }

  /* ── Awards ── */
  .awards-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }
  .award-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-top: 3px solid var(--gold);
    border-radius: 12px;
    padding: 2rem;
    text-align: center;
    transition: transform 0.3s, border-color 0.3s;
  }
  .award-card:hover {
    transform: translateY(-4px);
    border-color: var(--border-light);
  }
  .award-icon {
    font-size: 1.5rem;
    color: var(--gold);
    margin-bottom: 1rem;
  }
  .award-year {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    color: var(--gold);
    margin-bottom: 0.75rem;
  }
  .award-name {
    font-size: 1rem;
    font-weight: 600;
    line-height: 1.4;
  }
  .award-detail {
    font-size: 0.85rem;
    color: var(--text-secondary);
    margin-top: 0.5rem;
  }
  @media (max-width: 768px) {
    .awards-grid {
      grid-template-columns: 1fr;
    }
  }

  /* ── Skills & Activities ── */
  .two-col {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
  }
  .skills-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }
  .skill-tag {
    display: inline-block;
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--text);
    background: var(--bg-card);
    border: 1px solid var(--border);
    padding: 0.6rem 1.2rem;
    border-radius: 100px;
    transition: border-color 0.3s, background 0.3s;
  }
  .skill-tag:hover {
    border-color: var(--accent);
    background: var(--bg-card-hover);
  }
  .activities-list {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }
  .activity-item {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    padding-bottom: 1.25rem;
    border-bottom: 1px solid var(--border);
  }
  .activity-item:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }
  .activity-role {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--text);
  }
  .activity-org {
    font-size: 0.85rem;
    color: var(--text-secondary);
  }
  .activity-date {
    font-size: 0.75rem;
    color: var(--text-muted);
    margin-top: 0.15rem;
  }
  @media (max-width: 768px) {
    .two-col {
      grid-template-columns: 1fr;
      gap: 3rem;
    }
  }

  /* ── Contact ── */
  .contact-content {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .contact-heading {
    font-size: clamp(2.5rem, 6vw, 4rem);
    font-weight: 800;
    margin-bottom: 3rem;
  }
  .contact-links {
    display: flex;
    gap: 3rem;
    flex-wrap: wrap;
    justify-content: center;
  }
  .contact-link {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    padding: 1.5rem 2rem;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 12px;
    min-width: 200px;
    transition: border-color 0.3s, transform 0.3s;
  }
  .contact-link:hover {
    border-color: var(--accent);
    transform: translateY(-4px);
  }
  .contact-link-label {
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--accent);
  }
  .contact-link-value {
    font-size: 0.95rem;
    font-weight: 500;
    color: var(--text);
  }
  .contact-signature {
    margin-top: 4rem;
    width: 180px;
    opacity: 0.5;
    filter: brightness(0) invert(1);
    mix-blend-mode: lighten;
  }

  /* ── Footer ── */
  .footer {
    text-align: center;
    padding: 2rem;
    font-size: 0.8rem;
    color: var(--text-muted);
    background: var(--bg-alt);
  }
</style>

<!-- ═══════════════════════════════════════════════════════
     ANIMATIONS
     ═══════════════════════════════════════════════════════ -->
<script>
  import Lenis from 'lenis';
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  // ── Smooth scroll ──
  const lenis = new Lenis({
    lerp: 0.09,
    wheelMultiplier: 0.8,
  });
  lenis.on('scroll', ScrollTrigger.update);
  gsap.ticker.add((time) => lenis.raf(time * 1000));
  gsap.ticker.lagSmoothing(0);

  // ── Mobile nav toggle ──
  const navToggle = document.getElementById('nav-toggle');
  const nav = document.getElementById('nav');
  navToggle?.addEventListener('click', () => {
    nav?.classList.toggle('open');
  });

  // ── Nav background on scroll ──
  window.addEventListener('scroll', () => {
    nav?.classList.toggle('scrolled', window.scrollY > 50);
  });

  // ── Nav smooth scroll links ──
  document.querySelectorAll('.nav-links a, .nav-logo').forEach(link => {
    link.addEventListener('click', (e) => {
      const href = (link as HTMLAnchorElement).getAttribute('href');
      if (href?.startsWith('#')) {
        e.preventDefault();
        const target = document.querySelector(href);
        if (target) lenis.scrollTo(target as HTMLElement);
        nav?.classList.remove('open');
      }
    });
  });

  // ── Hero entrance (one-time, on load) ──
  const heroTl = gsap.timeline({ delay: 0.2 });
  heroTl
    .from('.hero-name-line', {
      y: 80,
      opacity: 0,
      duration: 1,
      stagger: 0.15,
      ease: 'power3.out',
    })
    .from('.hero-divider', {
      scaleX: 0,
      duration: 0.7,
      ease: 'power2.out',
    }, '-=0.4')
    .from('.hero-tagline', {
      y: 20,
      opacity: 0,
      duration: 0.7,
      ease: 'power2.out',
    }, '-=0.3')
    .from('.hero-scroll-hint', {
      opacity: 0,
      duration: 0.6,
    }, '-=0.3');

  // ── Hero pin + fade on scroll ──
  gsap.timeline({
    scrollTrigger: {
      trigger: '#hero',
      start: 'top top',
      end: '+=80%',
      scrub: 0.6,
      pin: true,
    }
  })
    .to('.hero-content', { y: -80, opacity: 0, scale: 0.97 })
    .to('.hero-scroll-hint', { opacity: 0 }, 0);

  // ── About text: word-by-word reveal ──
  document.querySelectorAll('[data-reveal-text]').forEach(el => {
    const text = el.textContent?.trim() || '';
    el.innerHTML = text.split(/\s+/).map(word =>
      `<span style="display:inline-block">${word}&nbsp;</span>`
    ).join('');

    const words = el.querySelectorAll('span');
    gsap.set(words, { opacity: 0.12 });

    gsap.to(words, {
      opacity: 1,
      stagger: 0.02,
      scrollTrigger: {
        trigger: el,
        start: 'top 70%',
        end: 'bottom 40%',
        scrub: true,
      }
    });
  });

  // ── Education: GPA scale-in ──
  gsap.from('.gpa-number', {
    scale: 2,
    opacity: 0,
    scrollTrigger: {
      trigger: '#education',
      start: 'top 65%',
      end: 'top 30%',
      scrub: true,
    }
  });
  gsap.from('.gpa-label', {
    opacity: 0,
    scrollTrigger: {
      trigger: '#education',
      start: 'top 55%',
      end: 'top 30%',
      scrub: true,
    }
  });
  gsap.from('.edu-details', {
    y: 40,
    opacity: 0,
    scrollTrigger: {
      trigger: '.edu-details',
      start: 'top 80%',
      end: 'top 45%',
      scrub: true,
    }
  });

  // ── Experience cards: slide in ──
  document.querySelectorAll('.exp-card').forEach((card) => {
    gsap.from(card, {
      y: 60,
      opacity: 0,
      scrollTrigger: {
        trigger: card,
        start: 'top 88%',
        end: 'top 55%',
        scrub: true,
      }
    });
  });

  // ── Awards: staggered entrance ──
  gsap.from('.award-card', {
    y: 50,
    opacity: 0,
    stagger: 0.1,
    scrollTrigger: {
      trigger: '.awards-grid',
      start: 'top 78%',
      end: 'top 38%',
      scrub: true,
    }
  });

  // ── Skills: pop in ──
  gsap.from('.skill-tag', {
    scale: 0.8,
    opacity: 0,
    stagger: 0.04,
    scrollTrigger: {
      trigger: '.skills-grid',
      start: 'top 78%',
      end: 'top 45%',
      scrub: true,
    }
  });

  // ── Activities: slide from right ──
  gsap.from('.activity-item', {
    x: 30,
    opacity: 0,
    stagger: 0.06,
    scrollTrigger: {
      trigger: '.activities-list',
      start: 'top 78%',
      end: 'top 38%',
      scrub: true,
    }
  });

  // ── Contact: fade in ──
  gsap.from('.contact-content > *', {
    y: 30,
    opacity: 0,
    stagger: 0.08,
    scrollTrigger: {
      trigger: '#contact',
      start: 'top 68%',
      end: 'top 35%',
      scrub: true,
    }
  });

  // ── Section labels ──
  document.querySelectorAll('.section-label').forEach(label => {
    gsap.from(label, {
      x: -20,
      opacity: 0,
      scrollTrigger: {
        trigger: label,
        start: 'top 88%',
        end: 'top 68%',
        scrub: true,
      }
    });
  });

  // ── Scroll hint pulsing line ──
  gsap.to('.scroll-line', {
    scaleY: 0,
    transformOrigin: 'bottom',
    duration: 1.5,
    repeat: -1,
    yoyo: true,
    ease: 'power1.inOut',
  });
</script>
