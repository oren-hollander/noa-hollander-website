---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Noa Hollander — Aviation Management">

  <!-- ═══════════════ NAVIGATION ═══════════════ -->
  <nav class="nav" id="nav">
    <div class="nav-inner">
      <a href="#hero" class="nav-logo" aria-label="NH">
        <svg id="nav-logo-svg" viewBox="-4 -8 48 64" width="30" height="40" fill="#d4a853">
          <path id="nav-logo-bg" fill="#131c2e"/>
          <path id="nav-logo-bar-l"/>
          <path id="nav-logo-bar-r"/>
          <path id="nav-logo-morph"/>
        </svg>
      </a>
      <div class="nav-links" id="nav-links">
        <a href="#about">About</a>
        <a href="#education">Education</a>
        <a href="#experience">Experience</a>
        <a href="#awards">Awards</a>
        <a href="#contact">Contact</a>
      </div>
      <button class="nav-toggle" id="nav-toggle" aria-label="Toggle menu">
        <span></span>
        <span></span>
      </button>
    </div>
  </nav>

  <!-- ═══════════════ HERO ═══════════════ -->
  <section id="hero" class="hero">
    <div class="hero-bg">
      <div class="hero-photo"></div>
      <div class="hero-gradient"></div>
      <div class="hero-stars"></div>
      <div class="hero-glow"></div>
    </div>
    <div class="hero-content">
      <h1 class="hero-name">
        <span class="hero-name-line">Noa</span>
        <span class="hero-name-line">Hollander</span>
      </h1>
      <div class="hero-divider"></div>
      <p class="hero-tagline">Aviation Management</p>
    </div>
    <div class="hero-scroll-hint">
      <span>Scroll</span>
      <div class="scroll-line"></div>
    </div>
  </section>

  <!-- ═══════════════ ABOUT ═══════════════ -->
  <section id="about" class="section">
    <div class="container">
      <span class="section-label">About</span>
      <p class="about-text" data-reveal-text>
        From coordinating helicopter squadron training plans in the Israeli Air Force
        to pursuing a degree in Aviation Management at Florida Tech — my path has always
        pointed skyward. I combine military discipline with academic excellence, driven
        by a vision of shaping the future of airport planning and design.
      </p>
    </div>
  </section>

  <!-- ═══════════════ EDUCATION ═══════════════ -->
  <section id="education" class="section section--alt">
    <div class="container">
      <span class="section-label">Education</span>
      <div class="edu-layout">
        <div class="gpa-display">
          <span class="gpa-number">4.0</span>
          <span class="gpa-label">GPA</span>
        </div>
        <div class="edu-details">
          <h2 class="edu-school">Florida Institute of Technology</h2>
          <p class="edu-location">Melbourne, FL</p>
          <p class="edu-degree">Bachelor of Science in Aviation Management</p>
          <p class="edu-date">Expected Graduation · May 2028</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════ EXPERIENCE ═══════════════ -->
  <section id="experience" class="section">
    <div class="container">
      <span class="section-label">Experience</span>

      <div class="exp-card exp-card--military">
        <div class="exp-accent"></div>
        <div class="exp-body">
          <div class="exp-header">
            <div>
              <h3 class="exp-org">Israeli Air Force</h3>
              <p class="exp-role">Staff Sergeant · Training Planning & Coordination NCO</p>
            </div>
            <span class="exp-date">May 2021 — Sep 2023</span>
          </div>
          <ul class="exp-list">
            <li>Oversaw training plans for operational helicopter squadrons, ensuring operational proficiency</li>
            <li>Developed and managed training exercises in a dynamic, high-pressure environment</li>
            <li>Coordinated flight plans in communication with multiple units and authorities</li>
            <li>Maintained pilot records and detailed flight logs in compliance with military standards</li>
            <li>Optimized and implemented new procedures to improve efficiency and safety</li>
          </ul>
        </div>
      </div>

      <div class="exp-card">
        <div class="exp-accent"></div>
        <div class="exp-body">
          <div class="exp-header">
            <div>
              <h3 class="exp-org">Florida Institute of Technology</h3>
              <p class="exp-role">Residence Life Marketing & Communication Assistant</p>
            </div>
            <span class="exp-date">Sep 2025 — Present</span>
          </div>
          <ul class="exp-list">
            <li>Promoted Residence Life and Housing events through social media and publications</li>
            <li>Designed and produced marketing materials for departmental branding and outreach</li>
          </ul>
        </div>
      </div>

      <div class="exp-card">
        <div class="exp-accent"></div>
        <div class="exp-body">
          <div class="exp-header">
            <div>
              <h3 class="exp-org">Florida Institute of Technology</h3>
              <p class="exp-role">Resident Assistant</p>
            </div>
            <span class="exp-date">Aug 2025 — Present</span>
          </div>
          <ul class="exp-list">
            <li>Assisted 380 students by providing resources and support for academic and personal success</li>
            <li>Developed educational and interactive programs tailored to residents' interests</li>
            <li>Planned, organized, and executed three monthly events for community engagement</li>
            <li>Collaborated with staff on conflict resolution to support a positive living environment</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════ AWARDS ═══════════════ -->
  <section id="awards" class="section section--alt">
    <div class="container">
      <span class="section-label">Awards & Honors</span>
      <div class="awards-grid">
        <div class="award-card">
          <div class="award-icon">★</div>
          <div class="award-year">2025</div>
          <h3 class="award-name">Tony Jannus Distinguished Aviation Society Scholars Award</h3>
        </div>
        <div class="award-card">
          <div class="award-icon">★</div>
          <div class="award-year">2024–25</div>
          <h3 class="award-name">Dean's List</h3>
          <p class="award-detail">2 consecutive semesters</p>
        </div>
        <div class="award-card">
          <div class="award-icon">★</div>
          <div class="award-year">2022</div>
          <h3 class="award-name">Tel Nof Airbase Excellence Award</h3>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════ SKILLS & ACTIVITIES ═══════════════ -->
  <section id="skills" class="section">
    <div class="container two-col">
      <div>
        <span class="section-label">Skills</span>
        <div class="skills-grid">
          <span class="skill-tag">Leadership & Team Coordination</span>
          <span class="skill-tag">High-Pressure Adaptability</span>
          <span class="skill-tag">Attention to Detail</span>
          <span class="skill-tag">Records & Data Management</span>
          <span class="skill-tag">Procedure Implementation</span>
          <span class="skill-tag">Microsoft Office</span>
          <span class="skill-tag">Canva</span>
        </div>
      </div>
      <div>
        <span class="section-label">Activities</span>
        <div class="activities-list">
          <div class="activity-item">
            <span class="activity-role">Secretary & Historian</span>
            <span class="activity-org">International Society of Air Safety Investigators</span>
            <span class="activity-date">Dec 2024 — Present</span>
          </div>
          <div class="activity-item">
            <span class="activity-role">Treasurer & Secretary</span>
            <span class="activity-org">Florida Tech's Mishpacha</span>
            <span class="activity-date">Feb 2025 — Present</span>
          </div>
          <div class="activity-item">
            <span class="activity-role">Secretary</span>
            <span class="activity-org">Phi Eta Sigma National Honor Society</span>
            <span class="activity-date">May 2025 — Present</span>
          </div>
          <div class="activity-item">
            <span class="activity-role">Member</span>
            <span class="activity-org">Collegiate Aviation Business Executives</span>
            <span class="activity-date">Oct 2024</span>
          </div>
          <div class="activity-item">
            <span class="activity-role">Member</span>
            <span class="activity-org">Women in Aviation, Florida Tech Chapter</span>
            <span class="activity-date">Oct 2024</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════ CONTACT ═══════════════ -->
  <section id="contact" class="section section--alt">
    <div class="container contact-content">
      <span class="section-label">Get in Touch</span>
      <h2 class="contact-heading">Let's Connect</h2>
      <div class="contact-links">
        <a href="tel:321-381-1034" class="contact-link">
          <span class="contact-link-label">Phone</span>
          <span class="contact-link-value">321-381-1034</span>
        </a>
        <a href="mailto:nhollander2024@my.fit.edu" class="contact-link">
          <span class="contact-link-label">Email</span>
          <span class="contact-link-value">nhollander2024@my.fit.edu</span>
        </a>
        <a href="https://linkedin.com/in/noa-hollander" target="_blank" rel="noopener" class="contact-link">
          <span class="contact-link-label">LinkedIn</span>
          <span class="contact-link-value">linkedin.com/in/noa-hollander</span>
        </a>
