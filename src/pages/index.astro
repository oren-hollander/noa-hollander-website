</style>

<!-- ═══════════════════════════════════════════════════════
     ANIMATIONS
     ═══════════════════════════════════════════════════════ -->
<script>
  import Lenis from 'lenis';
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  // ── Smooth scroll ──
  const lenis = new Lenis({
    lerp: 0.09,
    wheelMultiplier: 0.8,
  });
  lenis.on('scroll', ScrollTrigger.update);
  gsap.ticker.add((time) => lenis.raf(time * 1000));
  gsap.ticker.lagSmoothing(0);

  // ── Mobile nav toggle ──
  const navToggle = document.getElementById('nav-toggle');
  const nav = document.getElementById('nav');
  navToggle?.addEventListener('click', () => {
    nav?.classList.toggle('open');
  });

  // ── Nav background on scroll ──
  window.addEventListener('scroll', () => {
    nav?.classList.toggle('scrolled', window.scrollY > 50);
  });

  // ── Nav smooth scroll links ──
  document.querySelectorAll('.nav-links a, .nav-logo').forEach(link => {
    link.addEventListener('click', (e) => {
      const href = (link as HTMLAnchorElement).getAttribute('href');
      if (href?.startsWith('#')) {
        e.preventDefault();
        const target = document.querySelector(href);
        if (target) lenis.scrollTo(target as HTMLElement);
        nav?.classList.remove('open');
      }
    });
  });

  // ── Hero entrance (one-time, on load) ──
  const heroTl = gsap.timeline({ delay: 0.2 });
  heroTl
    .from('.hero-name-line', {
      y: 80,
      opacity: 0,
      duration: 1,
      stagger: 0.15,
      ease: 'power3.out',
    })
    .from('.hero-divider', {
      scaleX: 0,
      duration: 0.7,
      ease: 'power2.out',
    }, '-=0.4')
    .from('.hero-tagline', {
      y: 20,
      opacity: 0,
      duration: 0.7,
      ease: 'power2.out',
    }, '-=0.3')
    .from('.hero-scroll-hint', {
      opacity: 0,
      duration: 0.6,
    }, '-=0.3');

  // ── Hero pin + fade on scroll ──
  gsap.timeline({
    scrollTrigger: {
      trigger: '#hero',
      start: 'top top',
      end: '+=80%',
      scrub: 0.6,
      pin: true,
    }
  })
    .to('.hero-content', { y: -80, opacity: 0, scale: 0.97 })
    .to('.hero-scroll-hint', { opacity: 0 }, 0);

  // ── About text: word-by-word reveal ──
  document.querySelectorAll('[data-reveal-text]').forEach(el => {
    const text = el.textContent?.trim() || '';
    el.innerHTML = text.split(/\s+/).map(word =>
      `<span style="display:inline-block">${word}&nbsp;</span>`
    ).join('');

    const words = el.querySelectorAll('span');
    gsap.set(words, { opacity: 0.12 });

    gsap.to(words, {
      opacity: 1,
      stagger: 0.02,
      scrollTrigger: {
        trigger: el,
        start: 'top 70%',
        end: 'bottom 40%',
        scrub: true,
      }
    });
  });

  // ── Education: GPA scale-in ──
  gsap.from('.gpa-number', {
    scale: 2,
    opacity: 0,
    scrollTrigger: {
      trigger: '#education',
      start: 'top 65%',
      end: 'top 30%',
      scrub: true,
    }
  });
  gsap.from('.gpa-label', {
    opacity: 0,
    scrollTrigger: {
      trigger: '#education',
      start: 'top 55%',
      end: 'top 30%',
      scrub: true,
    }
  });
  gsap.from('.edu-details', {
    y: 40,
    opacity: 0,
    scrollTrigger: {
      trigger: '.edu-details',
      start: 'top 80%',
      end: 'top 45%',
      scrub: true,
    }
  });

  // ── Experience cards: slide in ──
  document.querySelectorAll('.exp-card').forEach((card) => {
    gsap.from(card, {
      y: 60,
      opacity: 0,
      scrollTrigger: {
        trigger: card,
        start: 'top 88%',
        end: 'top 55%',
        scrub: true,
      }
    });
  });

  // ── Awards: staggered entrance ──
  gsap.from('.award-card', {
    y: 50,
    opacity: 0,
    stagger: 0.1,
    scrollTrigger: {
      trigger: '.awards-grid',
      start: 'top 78%',
      end: 'top 38%',
      scrub: true,
    }
  });

  // ── Skills: pop in ──
  gsap.from('.skill-tag', {
    scale: 0.8,
    opacity: 0,
    stagger: 0.04,
    scrollTrigger: {
      trigger: '.skills-grid',
      start: 'top 78%',
      end: 'top 45%',
      scrub: true,
    }
  });

  // ── Activities: slide from right ──
  gsap.from('.activity-item', {
    x: 30,
    opacity: 0,
    stagger: 0.06,
    scrollTrigger: {
      trigger: '.activities-list',
      start: 'top 78%',
      end: 'top 38%',
      scrub: true,
    }
  });

  // ── Contact: fade in ──
  gsap.from('.contact-content > *', {
    y: 30,
    opacity: 0,
    stagger: 0.08,
    scrollTrigger: {
      trigger: '#contact',
      start: 'top 68%',
      end: 'top 35%',
      scrub: true,
    }
  });

  // ── Section labels ──
  document.querySelectorAll('.section-label').forEach(label => {
    gsap.from(label, {
      x: -20,
      opacity: 0,
      scrollTrigger: {
        trigger: label,
        start: 'top 88%',
        end: 'top 68%',
        scrub: true,
      }
    });
  });

  // ── Scroll hint pulsing line ──
  gsap.to('.scroll-line', {
    scaleY: 0,
    transformOrigin: 'bottom',
    duration: 1.5,
    repeat: -1,
    yoyo: true,
    ease: 'power1.inOut',
  });

  // ── Nav logo morph animation ──
  {
    const SW = 5.25;
    const HW = SW / 2;
    const K_SQ = 0.85;
    const K_CI = 0.5523;

    function vBar(cx: number, y1: number, y2: number, hw: number, k: number): string {
      const kh = k * hw, l = cx - hw, r = cx + hw, t = y1 - hw, b = y2 + hw;
      return `M ${r} ${y1} C ${r} ${y1-kh}, ${cx+kh} ${t}, ${cx} ${t} C ${cx-kh} ${t}, ${l} ${y1-kh}, ${l} ${y1} L ${l} ${y2} C ${l} ${y2+kh}, ${cx-kh} ${b}, ${cx} ${b} C ${cx+kh} ${b}, ${r} ${y2+kh}, ${r} ${y2} Z`;
    }

    function sqRect(x1: number, y1: number, x2: number, y2: number, cr: number, k: number): string {
      const kc = k * cr;
      return `M ${x1+cr} ${y1} L ${x2-cr} ${y1} C ${x2-cr+kc} ${y1}, ${x2} ${y1+cr-kc}, ${x2} ${y1+cr} L ${x2} ${y2-cr} C ${x2} ${y2-cr+kc}, ${x2-cr+kc} ${y2}, ${x2-cr} ${y2} L ${x1+cr} ${y2} C ${x1+cr-kc} ${y2}, ${x1} ${y2-cr+kc}, ${x1} ${y2-cr} L ${x1} ${y1+cr} C ${x1} ${y1+cr-kc}, ${x1+cr-kc} ${y1}, ${x1+cr} ${y1} Z`;
    }

    function lineOut(x1: number, y1: number, x2: number, y2: number, hw: number, k: number): string {
      const dx = x2-x1, dy = y2-y1, len = Math.sqrt(dx*dx+dy*dy);
      if (len < 0.001) {
        const kh = k*hw, l = x1-hw, r = x1+hw, t = y1-hw, b = y1+hw;
        return `M ${r} ${y1} C ${r} ${y1-kh}, ${x1+kh} ${t}, ${x1} ${t} C ${x1-kh} ${t}, ${l} ${y1-kh}, ${l} ${y1} C ${l} ${y1+kh}, ${x1-kh} ${b}, ${x1} ${b} C ${x1+kh} ${b}, ${r} ${y1+kh}, ${r} ${y1} Z`;
      }
      const ux=dx/len, uy=dy/len, px=-uy, py=ux;
      const r1x=x1+px*hw, r1y=y1+py*hw, l1x=x1-px*hw, l1y=y1-py*hw;
      const r2x=x2+px*hw, r2y=y2+py*hw, l2x=x2-px*hw, l2y=y2-py*hw;
      const kh=k*hw, tsx=x1-ux*hw, tsy=y1-uy*hw, tex=x2+ux*hw, tey=y2+uy*hw;
      return `M ${r1x} ${r1y} L ${r2x} ${r2y} C ${r2x+ux*kh} ${r2y+uy*kh}, ${tex+px*kh} ${tey+py*kh}, ${tex} ${tey} C ${tex-px*kh} ${tey-py*kh}, ${l2x+ux*kh} ${l2y+uy*kh}, ${l2x} ${l2y} L ${l1x} ${l1y} C ${l1x-ux*kh} ${l1y-uy*kh}, ${tsx-px*kh} ${tsy-py*kh}, ${tsx} ${tsy} C ${tsx+px*kh} ${tsy+py*kh}, ${r1x-ux*kh} ${r1y-uy*kh}, ${r1x} ${r1y} Z`;
    }

    function lrp(a: number, b: number, t: number): number { return a+(b-a)*t; }
    function eas(t: number): number { return t<0.5 ? 4*t*t*t : 1-Math.pow(-2*t+2,3)/2; }

    const bgEl = document.getElementById('nav-logo-bg');
    const blEl = document.getElementById('nav-logo-bar-l');
    const brEl = document.getElementById('nav-logo-bar-r');
    const mEl = document.getElementById('nav-logo-morph');

    if (bgEl && blEl && brEl && mEl) {
      bgEl.setAttribute('d', sqRect(-4, -8, 44, 56, 10, K_SQ));
      blEl.setAttribute('d', vBar(6, 4, 44, HW, K_SQ));
      brEl.setAttribute('d', vBar(34, 4, 44, HW, K_SQ));

      const cir = {x1:20, y1:24, x2:20, y2:24, hw:5.25};
      const hSt = {x1:13.875, y1:24, x2:26.125, y2:24, hw:HW};
      const nSt = {x1:13.875, y1:15.25, x2:26.125, y2:32.75, hw:HW};
      const MR = 1600, HN = 1500, HH = 3000, TOT = MR+HN+MR+HH;

      function mf(from: typeof cir, to: typeof cir, fk: number, tk: number, st: number) {
        mEl!.setAttribute('d', lineOut(lrp(from.x1,to.x1,st), lrp(from.y1,to.y1,st), lrp(from.x2,to.x2,st), lrp(from.y2,to.y2,st), lrp(from.hw,to.hw,st), lrp(fk,tk,st)));
      }

      function logoTick(ts: number) {
        const c = ts % TOT;
        if (c < HN) {
          mEl!.setAttribute('d', lineOut(nSt.x1,nSt.y1,nSt.x2,nSt.y2,nSt.hw,K_SQ));
        } else if (c < HN+MR) {
          const r = eas((c-HN)/MR);
          r<=0.5 ? mf(nSt,cir,K_SQ,K_CI,r*2) : mf(cir,hSt,K_CI,K_SQ,(r-0.5)*2);
        } else if (c < HN+MR+HH) {
          mEl!.setAttribute('d', lineOut(hSt.x1,hSt.y1,hSt.x2,hSt.y2,hSt.hw,K_SQ));
        } else {
          const r = eas((c-HN-MR-HH)/MR);
          r<=0.5 ? mf(hSt,cir,K_SQ,K_CI,r*2) : mf(cir,nSt,K_CI,K_SQ,(r-0.5)*2);
        }
        requestAnimationFrame(logoTick);
      }
      requestAnimationFrame(logoTick);
    }
  }

  // ── Compass needle animation ──
  {
    const ANGLE_H = 90;
    const ANGLE_N = 150;
    const TARGETS = [ANGLE_H, ANGLE_N];
    const SPIN_DUR = 3;
    const SETTLE_DUR = 2.5;
    const STATIC_DUR = 2;

    function spinVelocity(t: number): number {
      return 700
        + 300 * Math.sin(t * 3.1 + 0.5)
        + 250 * Math.sin(t * 8.7 + 1.2)
        + 200 * Math.cos(t * 14.3 + 0.3)
        + 150 * Math.sin(t * 21.1 + 2.1)
        + 100 * Math.cos(t * 31.7 + 0.8);
    }

    function nearestTarget(current: number, target: number): number {
      const mod = ((current % 360) + 360) % 360;
      let diff = target - mod;
      if (diff > 180) diff -= 360;
      if (diff < -180) diff += 360;
      return current + diff;
    }

    const needleEl = document.querySelector('.compass-needle');
    if (needleEl) {
      let angle = 0;
      let velocity = 350;
      let phase = 'spin';
      let phaseTime = 0;
      let targetIdx = 0;
      let settleTarget = 0;
      let lastTs: number | null = null;

      function tick(ts: number) {
        if (!lastTs) lastTs = ts;
        const dt = Math.min((ts - lastTs) / 1000, 0.05);
        lastTs = ts;
        phaseTime += dt;

        if (phase === 'spin') {
          const tv = spinVelocity(phaseTime);
          velocity += (tv - velocity) * dt * 10;
          angle += velocity * dt;
          if (phaseTime >= SPIN_DUR) {
            phase = 'settle';
            phaseTime = 0;
            settleTarget = nearestTarget(angle, TARGETS[targetIdx]);
            velocity *= 0.12;
          }
        } else if (phase === 'settle') {
          const stiffness = 80;
          const damping = 7;
          const force = -stiffness * (angle - settleTarget) - damping * velocity;
          velocity += force * dt;
          angle += velocity * dt;
          if (phaseTime >= SETTLE_DUR) {
            phase = 'static';
            phaseTime = 0;
            angle = settleTarget;
            velocity = 0;
          }
        } else {
          if (phaseTime >= STATIC_DUR) {
            phase = 'spin';
            phaseTime = 0;
            targetIdx = (targetIdx + 1) % TARGETS.length;
            velocity = 350;
          }
        }

        needleEl.setAttribute('transform', `rotate(${angle} 60 60)`);
        requestAnimationFrame(tick);
      }

      requestAnimationFrame(tick);
    }
  }
</script>
